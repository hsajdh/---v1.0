.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* === 甜蜜横幅 === */
.hero-banner {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8E9E 50%, #FFB3C1 100%);
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  text-align: center;
  color: #FFF;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 138, 0.25);
}

.hero-hearts {
  font-size: 36rpx;
  margin-bottom: 12rpx;
  letter-spacing: 8rpx;
}

.hero-msg {
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.hero-from {
  font-size: 22rpx;
  opacity: 0.85;
}

/* === 进度卡片 === */
.progress-card {
  background: #FFF;
}

.progress-circle-row {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.progress-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B8A, #FF8E9E);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFF;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.3);
}

.circle-percent {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.circle-label {
  font-size: 20rpx;
  opacity: 0.9;
  margin-top: 4rpx;
}

.progress-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-val {
  font-size: 28rpx;
  font-weight: 700;
  color: #999;
}

.detail-val.current {
  color: var(--primary);
  font-size: 32rpx;
}

.detail-val.target {
  color: var(--success);
}

.detail-label {
  font-size: 22rpx;
  color: #999;
}

.bmi-info {
  text-align: center;
}

/* === 数据卡片网格 === */
.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.data-card {
  text-align: center;
  padding: 24rpx 16rpx;
  cursor: pointer;
  transition: transform 0.15s;
}

.data-card:active {
  transform: scale(0.96);
}

.data-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.data-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.data-label {
  font-size: 22rpx;
  color: var(--text-light);
}

.water-card {
  border-left: 4rpx solid #5BC0EB;
}

.cal-card {
  border-left: 4rpx solid var(--warning);
}

.ex-card {
  border-left: 4rpx solid var(--danger);
}

.point-card {
  border-left: 4rpx solid #FFD700;
}

/* 水杯进度点 */
.water-dots {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-top: 10rpx;
}

.water-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #E8E8E8;
}

.water-dot.filled {
  background: #5BC0EB;
}

/* 迷你进度条 */
.mini-bar {
  margin-top: 12rpx;
}

/* === 运动列表 === */
.empty-hint {
  text-align: center;
  color: var(--text-lighter);
  padding: 32rpx 0;
  font-size: 26rpx;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ex-item {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.ex-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.ex-name {
  flex: 1;
  font-size: 26rpx;
}

.ex-cal {
  color: var(--danger);
  font-weight: 600;
  font-size: 24rpx;
}

/* === 体重图表 === */
.chart-container {
  padding: 16rpx 0;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 200rpx;
  padding-top: 20rpx;
}

.chart-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.chart-bar {
  width: 40rpx;
  min-height: 8rpx;
  background: #F0D0D8;
  border-radius: 8rpx 8rpx 0 0;
  position: relative;
  transition: height 0.5s ease;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.chart-bar.today {
  background: linear-gradient(180deg, #FF6B8A, #FFB3C1);
}

.bar-val {
  font-size: 18rpx;
  color: #999;
  position: absolute;
  top: -28rpx;
  white-space: nowrap;
}

.chart-bar.today .bar-val {
  color: var(--primary);
  font-weight: 700;
}

.bar-date {
  font-size: 18rpx;
  color: #999;
  margin-top: 8rpx;
}

/* === 饮食时间线 === */
.meal-timeline {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.meal-item:last-child {
  border-bottom: none;
}

.meal-time {
  font-size: 28rpx;
  width: 120rpx;
  flex-shrink: 0;
}

.meal-suggest {
  flex: 1;
  font-size: 26rpx;
  color: #555;
}

.meal-cal {
  font-size: 24rpx;
  color: var(--text-light);
  flex-shrink: 0;
}
