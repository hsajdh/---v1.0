.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* 清真横幅 */
.halal-banner {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #2E7D32;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.halal-icon { font-size: 32rpx; }

/* 分类标签 */
.category-tabs {
  display: flex;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.tab-item {
  display: inline-block;
  padding: 14rpx 22rpx;
  margin-right: 12rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #FFF;
  color: #666;
  flex-shrink: 0;
  transition: all 0.2s;
}

.tab-item.active {
  background: var(--primary);
  color: #FFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 138, 0.25);
}

.category-hint {
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* 添加按钮 */
.add-bar {
  margin-bottom: 20rpx;
}

.add-btn {
  width: 100%;
  padding: 20rpx;
  font-size: 28rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.25);
}

/* 食物卡片 */
.food-card {
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  cursor: pointer;
  transition: transform 0.15s;
  position: relative;
}

.food-card:active {
  transform: scale(0.98);
}

.food-card.custom-food {
  border-left: 4rpx solid #FF9800;
  background: #FFFDF5;
}

.custom-badge {
  display: inline-block;
  padding: 2rpx 10rpx;
  background: #FFF3E0;
  color: #E65100;
  font-size: 20rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}

.food-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.food-icon {
  font-size: 38rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.food-meta {
  font-size: 22rpx;
}

.food-cal {
  text-align: center;
  flex-shrink: 0;
  min-width: 90rpx;
}

.cal-val {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
  line-height: 1;
}

.cal-unit {
  font-size: 20rpx;
  color: var(--text-light);
}

.delete-tip {
  position: absolute;
  right: 24rpx;
  bottom: 10rpx;
  font-size: 18rpx;
  color: #FF9800;
}

.empty-hint {
  text-align: center;
  color: #bbb;
  padding: 80rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ==================== 弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
  animation: fadeIn 0.2s;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  flex: 1;
  max-height: 55vh;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 10rpx;
}

.form-input {
  background: var(--bg);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-picker {
  background: var(--bg);
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: var(--primary);
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-half {
  flex: 1;
}

.modal-footer {
  padding: 20rpx 32rpx 40rpx;
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer .btn-primary {
  flex: 1;
  padding: 22rpx;
  font-size: 28rpx;
  border-radius: 48rpx;
}

.modal-footer .btn-outline {
  padding: 16rpx 28rpx;
  font-size: 24rpx;
}
