.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* === 日历 === */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  text-align: center;
}

.cal-day-header {
  font-size: 22rpx;
  color: #999;
  padding: 8rpx 0;
}

.cal-day {
  aspect-ratio: 1;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  background: #F8F8F8;
  position: relative;
}

.cal-day.future {
  opacity: 0.3;
}

.cal-day.checked {
  background: linear-gradient(135deg, #FF6B8A, #FFB3C1);
  color: #FFF;
}

.cal-day.today {
  border: 2rpx solid var(--primary);
}

.cal-day.today.checked {
  border: 2rpx solid #FFF;
}

.cal-check-mark {
  position: absolute;
  bottom: 2rpx;
  right: 4rpx;
  font-size: 16rpx;
}

.cal-todo {
  font-size: 18rpx;
  color: var(--primary);
}

/* === 已打卡横幅 === */
.checked-banner {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #2E7D32;
  margin-bottom: 24rpx;
}

.checked-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 8rpx;
}

/* === 打卡字段 === */
.checkin-field {
  margin-bottom: 28rpx;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.field-icon {
  font-size: 32rpx;
}

.field-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.field-input {
  flex: 1;
  height: 90rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.field-unit {
  font-size: 28rpx;
  color: #999;
}

/* === 运动选择 === */
.exercise-select {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ex-option {
  padding: 14rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.ex-option.selected {
  border-color: var(--primary);
  background: var(--primary-light);
}

.ex-cal-text {
  font-size: 20rpx;
  color: var(--danger);
}

/* === 喝水快捷 === */
.water-quick-set {
  display: flex;
  gap: 12rpx;
}

.water-qbtn {
  flex: 1;
  padding: 16rpx;
  background: #F0F0F0;
  border-radius: 12rpx;
  font-size: 24rpx;
  border: none;
  text-align: center;
  color: #999;
}

.water-qbtn.done {
  background: #5BC0EB;
  color: #FFF;
}

/* === 拍照 === */
.photo-area {
  width: 200rpx;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #DDD;
}

.photo-placeholder {
  text-align: center;
  color: #CCC;
  font-size: 24rpx;
}

.photo-plus {
  font-size: 60rpx;
  display: block;
  line-height: 1;
  color: #DDD;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

/* === 提交 === */
.submit-area {
  margin-top: 10rpx;
  margin-bottom: 30rpx;
}

.submit-area .btn-primary {
  display: block;
  width: 100%;
  padding: 26rpx;
  font-size: 32rpx;
}

/* === 历史 === */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.history-item {
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.history-date {
  font-size: 28rpx;
  font-weight: 600;
}
