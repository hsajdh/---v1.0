.container {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

/* === 积分头部 === */
.points-hero {
  background: linear-gradient(135deg, #FFD700, #FFA000);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 160, 0, 0.25);
}

.points-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #FFF;
  flex-shrink: 0;
}

.points-num {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.points-label {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.points-desc {
  color: #FFF;
  font-size: 24rpx;
  line-height: 1.6;
}

/* === 积分规则 === */
.rule-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #555;
}

.rule-icon {
  font-size: 28rpx;
}

/* === 奖励网格 === */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  margin-top: 10rpx;
}

.reward-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.reward-card {
  padding: 24rpx;
  text-align: center;
  position: relative;
  cursor: pointer;
  transition: all 0.2s;
  overflow: hidden;
}

.reward-card:active {
  transform: scale(0.96);
}

.reward-card.locked {
  opacity: 0.5;
  filter: grayscale(30%);
}

.reward-icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
}

.reward-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.reward-desc {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.reward-cost {
  background: linear-gradient(135deg, #FFF8E1, #FFECB3);
  border-radius: 20rpx;
  padding: 8rpx 16rpx;
  display: inline-block;
}

.cost-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #F57F17;
}

.cost-label {
  font-size: 20rpx;
  color: #F9A825;
  margin-left: 4rpx;
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
}

.lock-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

/* === 已兑换 === */
.redeemed-item {
  padding: 20rpx 24rpx;
  margin-bottom: 12rpx;
}

.redeemed-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

/* === 惩罚箱 === */
.punishment-card {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}

.punishment-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.pun-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx;
  font-size: 24rpx;
}

.pun-icon {
  font-size: 28rpx;
}

.pun-name {
  color: #BF360C;
}
