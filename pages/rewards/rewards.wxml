<scroll-view scroll-y class="container">

  <!-- 积分头部 -->
  <view class="points-hero">
    <view class="points-circle">
      <text class="points-num">{{totalPoints}}</text>
      <text class="points-label">当前积分</text>
    </view>
    <view class="points-desc">
      <text>每天打卡、运动、健康饮食</text>
      <text>都能获得积分哦～ 💪</text>
    </view>
  </view>

  <!-- 积分规则 -->
  <view class="card rules-card">
    <view class="card-title">📋 积分规则</view>
    <view class="rule-grid">
      <view class="rule-item">
        <text class="rule-icon">✅</text>
        <text>每日打卡 +5分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">💧</text>
        <text>喝满8杯水 +3分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🏃‍♀️</text>
        <text>每次运动 +10分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🥗</text>
        <text>记录饮食 +2分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">📸</text>
        <text>拍对比照 +5分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">📉</text>
        <text>每周掉秤 >0.5kg +20分</text>
      </view>
    </view>
  </view>

  <!-- 奖励列表 -->
  <view class="section-title">🎁 奖励兑换</view>
  <view class="reward-grid">
    <view
      wx:for="{{rewards}}"
      wx:key="id"
      class="card reward-card {{totalPoints >= item.points ? 'available' : 'locked'}}"
      bindtap="redeemReward"
      data-item="{{item}}"
    >
      <view class="reward-icon">{{item.icon}}</view>
      <view class="reward-name">{{item.name}}</view>
      <view class="reward-desc">{{item.desc}}</view>
      <view class="reward-cost">
        <text class="cost-num">{{item.points}}</text>
        <text class="cost-label">积分</text>
      </view>
      <view wx:if="{{totalPoints < item.points}}" class="lock-overlay">
        <text class="lock-icon">🔒</text>
        <text>还差{{item.points - totalPoints}}分</text>
      </view>
    </view>
  </view>

  <!-- 已兑换记录 -->
  <view wx:if="{{redeemedList.length > 0}}" class="section-title mt-2">📜 已兑换记录</view>
  <view wx:for="{{redeemedList}}" wx:key="id" class="card redeemed-item flex-between">
    <view class="flex-row">
      <text class="redeemed-icon">{{item.icon}}</text>
      <text>{{item.name}}</text>
    </view>
    <text class="text-sm text-light">{{item.date}}</text>
  </view>

  <!-- 惩罚列表（趣味） -->
  <view class="section-title mt-2">😈 偷懒惩罚箱</view>
  <view class="card punishment-card">
    <view class="text-sm text-light mb-1">连续3天不打卡，随机抽取一个惩罚：</view>
    <view class="punishment-grid">
      <view wx:for="{{punishments}}" wx:key="id" class="pun-item">
        <text class="pun-icon">{{item.icon}}</text>
        <text class="pun-name">{{item.name}}</text>
      </view>
    </view>
    <view class="text-center mt-1">
      <button class="btn-outline btn-sm" bindtap="randomPunishment">🎲 随机抽取惩罚</button>
    </view>
  </view>

  <view style="height:40rpx;"></view>
</scroll-view>
